# DigitalOcean serverida ishlatish uchun .env fayli
# Bu faylni server-ga ko'chirib, qiymatlarni to'ldiring

# PostgreSQL ma'lumotlar bazasi
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_NAME=crm_db

# JWT maxfiy kalit (kamida 32 ta tasodifiy belgi)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server IP yoki domen nomi
# Masalan: http://142.93.100.200 yoki https://uits.uz
VITE_API_URL=http://YOUR_SERVER_IP
