# --- BACKEND SETTINGS ---
PORT=3000
JWT_SECRET=your_super_secret_key_here

# Database (DigitalOcean Managed DB or Docker DB)
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=crm_db
DB_SYNC=true

# --- FRONTEND SETTINGS ---
# Vite needs VITE_ prefix for environment variables to be accessible in the client
VITE_API_URL=https://your-backend-api-url.com
